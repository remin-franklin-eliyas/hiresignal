ENVIRONMENT=local
LOG_LEVEL=INFO

GRAPH_TENANT_ID=00000000-0000-0000-0000-000000000000
GRAPH_CLIENT_ID=00000000-0000-0000-0000-000000000000
GRAPH_CLIENT_SECRET=replace-with-key-vault-or-local-secret
GRAPH_SCOPES=https://graph.microsoft.com/.default
GRAPH_BASE_URL=https://graph.microsoft.com/v1.0
GRAPH_WEBHOOK_CLIENT_STATE=replace-with-random-subscription-secret
GRAPH_MONITORED_USER_ID=recruiter@example.com

AZURE_AI_FOUNDRY_ENDPOINT=
AZURE_AI_FOUNDRY_API_KEY=
AZURE_AI_FOUNDRY_MODEL=gpt-4.1-mini
USE_LOCAL_SCORING_FALLBACK=true

DATABASE_URL=sqlite:///./hiresignal.local.sqlite3
PIPELINE_VERSION=2026.06.10
JOB_RUBRIC_PATH=config/job_rubric.sample.json
TEAMS_CHANNEL_ID=replace-at-runtime
FABRIC_WORKSPACE_ID=replace-at-runtime
FABRIC_LAKEHOUSE_ID=replace-at-runtime
FABRIC_AUDIT_MODE=sqlite
FABRIC_AUDIT_ENDPOINT=
FABRIC_AUDIT_TOKEN=
